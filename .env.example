# Copy to .env and fill in real values. .env is gitignored — never commit real secrets.

# --- Phase 4 CDC stack (docker-compose.yml) ---

# Postgres (CDC source — ADR-006). Local dev-only credentials; this database is
# never exposed outside the Docker network in this project.
POSTGRES_USER=retail
POSTGRES_PASSWORD=changeme
POSTGRES_DB=retail

# Kafka KRaft cluster ID (ADR-005). Not a secret — just needs to stay stable
# across container restarts as long as the kafka_data volume persists.
# Regenerate with: docker run --rm confluentinc/cp-kafka:7.6.1 kafka-storage random-uuid
KAFKA_CLUSTER_ID=Hti09RslR7m1AhIqRvJ-qA

# --- Simulator (Phase 4a) ---
# Points the simulator at the Postgres service above instead of local DuckDB.
DATABASE_URL=postgresql://retail:changeme@localhost:5432/retail
